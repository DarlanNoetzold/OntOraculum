<owl:Class rdf:about="#SLA">
  <rdfs:subClassOf rdf:resource="#Metric"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#contributesTo"/>
      <owl:someValuesFrom rdf:resource="#QualityOfService"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#contributesTo"/>
      <owl:someValuesFrom rdf:resource="#Availability"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

