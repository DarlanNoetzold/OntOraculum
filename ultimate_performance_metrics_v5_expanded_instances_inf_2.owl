<owl:NamedIndividual rdf:about="#high_cpu_instance">
  <rdf:type rdf:resource="#CPUUsage"/>
  <dependsOn rdf:resource="#high_energy_usage_instance"/>
  <impacts rdf:resource="#high_resource_usage_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">85.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CPU usage above 80%, triggering high resource usage.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#low_memory_instance">
  <rdf:type rdf:resource="#MemoryUsage"/>
  <dependsOn rdf:resource="#critical_disk_instance"/>
  <impacts rdf:resource="#low_memory_scenario_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memory usage is less than 30%, triggering low memory scenario.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#overloaded_gpu_instance">
  <rdf:type rdf:resource="#GPUUsage"/>
  <dependsOn rdf:resource="#inefficient_energy_instance"/>
  <rdf:type rdf:resource="#OverloadedGPU"/>
  <impacts rdf:resource="#overloaded_gpu_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">90.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GPU usage above 85%, triggering overloaded GPU.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#critical_disk_instance">
  <rdf:type rdf:resource="#DiskReadWriteSpeed"/>
  <dependsOn rdf:resource="#stable_resource_instance"/>
  <impacts rdf:resource="#critical_disk_performance_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MB/s</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disk read/write speed below 10 MB/s, triggering critical disk performance.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#stable_resource_instance">
  <rdf:type rdf:resource="#CPUUsage"/>
  <impacts rdf:resource="#stable_resource_usage_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">45.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stable CPU usage below 50% with memory usage below 60%, triggering stable resource usage.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#unbalanced_network_instance">
  <rdf:type rdf:resource="#NetworkLatency"/>
  <dependsOn rdf:resource="#high_energy_usage_instance"/>
  <rdf:type rdf:resource="#UnbalancedNetwork"/>
  <impacts rdf:resource="#unbalanced_network_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">160.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ms</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Network latency above 150 ms, triggering unbalanced network.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#high_energy_usage_instance">
  <rdf:type rdf:resource="#PowerConsumption"/>
  <rdf:type rdf:resource="#HighEnergyUsage"/>
  <impacts rdf:resource="#high_energy_usage_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">250.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watts</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Power consumption greater than 200W, triggering high energy usage.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#inefficient_energy_instance">
  <rdf:type rdf:resource="#EnergyEfficiency"/>
  <rdf:type rdf:resource="#InefficientEnergy"/>
  <impacts rdf:resource="#inefficient_energy_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">60.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Energy efficiency below 70%, triggering inefficient energy.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#overloaded_devices_instance">
  <rdf:type rdf:resource="#PowerConsumption"/>
  <dependsOn rdf:resource="#critical_disk_instance"/>
  <rdf:type rdf:resource="#OverloadedDevices"/>
  <impacts rdf:resource="#overloaded_devices_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">130.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watts</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Power consumption above 120W, triggering overloaded devices.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#high_error_rate_instance">
  <rdf:type rdf:resource="#ErrorRates"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">30.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Error rate above 25%, triggering high error rate scenario.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#potential_intrusion_instance">
  <rdf:type rdf:resource="#IntrusionAttempts"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">12.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">attempts/hour</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intrusion attempts above 10/hour, triggering potential intrusion scenario.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#malware_detected_instance">
  <rdf:type rdf:resource="#MalwareDetectionRate"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">detections/hour</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frequent malware detections above 5/hour, triggering malware detected.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#accurate_detection_instance">
  <rdf:type rdf:resource="#DetectionRates"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">96.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High detection accuracy, below 5% false positives, triggering accurate detection scenario.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#compromised_security_instance">
  <rdf:type rdf:resource="#CompromisedSecurity"/>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Compromised security detected due to high error rate and malware detections.</description>
</owl:NamedIndividual>

