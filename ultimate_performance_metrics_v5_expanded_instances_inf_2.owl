<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/ultimate_performance_metrics_v5_expanded_inf.owl"
         xmlns="http://example.org/ultimate_performance_metrics_v5_expanded_inf.owl#">

<owl:Ontology rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded_inf.owl"/>

<owl:ObjectProperty rdf:about="#dependsOn">
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="#Metric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#impacts">
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="#Metric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#influences">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="#Metric"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isMeasuredBy">
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="#Sensors"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#contributesTo">
  <rdfs:domain rdf:resource="#Metric"/>
  <rdfs:range rdf:resource="#SLA"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#optimizes">
  <rdfs:domain rdf:resource="#Energy"/>
  <rdfs:range rdf:resource="#Hardware"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#increases">
  <rdfs:domain rdf:resource="#Software"/>
  <rdfs:range rdf:resource="#PerformanceKPIs"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#reduces">
  <rdfs:domain rdf:resource="#Energy"/>
  <rdfs:range rdf:resource="#Downtime"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ensures">
  <rdfs:domain rdf:resource="#SecurityAndReliability"/>
  <rdfs:range rdf:resource="#QualityOfService"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#monitors">
  <rdfs:domain rdf:resource="#Sensors"/>
  <rdfs:range rdf:resource="#Software"/>
  <rdfs:range rdf:resource="#Network"/>
  <rdfs:range rdf:resource="#Hardware"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#enhances">
  <rdfs:domain rdf:resource="#Software"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#decreases">
  <rdfs:domain rdf:resource="#Energy"/>
  <rdfs:range rdf:resource="#NetworkLatency"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasValue">
  <rdfs:domain rdf:resource="#CPUUsage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#unit">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#description">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#timestamp">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#max_value">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#min_value">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#threshold">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#source">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#status">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#average">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#trend">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Metric">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Hardware">
  <rdfs:subClassOf rdf:resource="#Metric"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#dependsOn"/>
      <owl:someValuesFrom rdf:resource="#Network"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#dependsOn"/>
