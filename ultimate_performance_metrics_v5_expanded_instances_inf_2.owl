<owl:NamedIndividual rdf:about="#low_power_instance">
  <rdf:type rdf:resource="#PowerConsumption"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">90.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watts</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low power consumption detected, under 100W.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#high_battery_instance">
  <rdf:type rdf:resource="#BatteryLife"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">95.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Battery life at optimal level, over 90%.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#optimal_energy_instance">
  <rdf:type rdf:resource="#EnergyEfficiency"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">92.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Energy efficiency above 90%, optimal energy usage.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#service_uptime_instance">
  <rdf:type rdf:resource="#ServiceUptime"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">98.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Service uptime is at 98%, high reliability.</description>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#false_positive_high_instance">
  <rdf:type rdf:resource="#FalsePositiveRate"/>
  <dependsOn rdf:resource="#high_error_rate_instance"/>
  <hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">12.0</hasValue>
  <unit rdf:datatype="http://www.w3.org/2001/XMLSchema#string">percentage</unit>
  <description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High false positive rate in security alerts.</description>
</owl:NamedIndividual>


