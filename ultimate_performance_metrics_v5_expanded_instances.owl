    </owl:DatatypeProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#unit -->

    <owl:DatatypeProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#unit">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#value -->

    <owl:DatatypeProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#AccurateDetectionScenario -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#AccurateDetectionScenario">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#AnomalyDetectedAt -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#AnomalyDetectedAt">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#AnomalyDetection -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#AnomalyDetection">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#SecurityAndReliability"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#description"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#timestamp"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#ApplicationAvailability -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#ApplicationAvailability">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Software"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#max_value"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#status"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#ApplicationDowntimeImpact -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#ApplicationDowntimeImpact">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#Availability -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Availability">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#SLA"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#timestamp"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#unit"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#BalancedEnergyUsage -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#BalancedEnergyUsage">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#BatteryLife -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#BatteryLife">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Energy"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#max_value"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#min_value"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#contributesTo"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#SLA"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPU -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPU">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Hardware"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#impacts"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPUUsage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#isMeasuredBy"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Sensors"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPUInstructionsPerSecond -->

    <owl:Class rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPUInstructionsPerSecond">
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPU"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#description"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#unit"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPUL1CacheUsage -->

