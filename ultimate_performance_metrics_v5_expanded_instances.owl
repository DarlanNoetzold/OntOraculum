        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#dependsOn"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Hardware"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#dependsOn"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Network"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#enhances"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Network"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#increases"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#PerformanceKPIs"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#isMeasuredBy"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Sensors"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


