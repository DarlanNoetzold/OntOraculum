<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ultimate_performance_metrics_v5_expanded.owl#"
     xml:base="http://example.org/ultimate_performance_metrics_v5_expanded.owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#contributesTo -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#contributesTo">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#SLA"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#decreases -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#decreases">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Energy"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#NetworkLatency"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#dependsOn -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#dependsOn">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#enhances -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#enhances">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Software"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#ensures -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#ensures">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#SecurityAndReliability"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#QualityOfService"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#impacts -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#impacts">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#increases -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#increases">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Software"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#PerformanceKPIs"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#influences -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#influences">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#isMeasuredBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#isMeasuredBy">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Metric"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Sensors"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#monitors -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#monitors">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Sensors"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Hardware"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Network"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Software"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#optimizes -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#optimizes">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Energy"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Hardware"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#reduces -->

    <owl:ObjectProperty rdf:about="http://example.org/ultimate_performance_metrics_v5_expanded.owl#reduces">
        <rdfs:domain rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Energy"/>
        <rdfs:range rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#Downtime"/>
    </owl:ObjectProperty>
    


