        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#average"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#unit"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ultimate_performance_metrics_v5_expanded.owl#value"/>
    </owl:Class>
    


    <!-- http://example.org/ultimate_performance_metrics_v5_expanded.owl#CPUL2CacheUsage -->

